{
  "name": "@pos/pos-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p ${WEB_PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:pre-release": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100 WEB_PORT=3100 playwright test tests/e2e/smoke tests/e2e/regression tests/e2e/mutations/purchase-order-approval.spec.ts --workers=1",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:regression": "playwright test tests/e2e/regression",
    "test:e2e:mutation": "playwright test tests/e2e/mutations",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
